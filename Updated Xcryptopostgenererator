<script>
// ── SECURITY ──
const APP_PASSWORD = 'vemdd71mrgdSixKZ';
const TOKEN_SECRET = '0mbCKgQorEzCpcCk8tKhjUbYMToqiNilGbT-RgZ3OrA';

async function sha256(msg) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(msg));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

async function hmac(msg, secret) {
  const key = await crypto.subtle.importKey('raw', new TextEncoder().encode(secret), {name:'HMAC',hash:'SHA-256'}, false, ['sign']);
  const sig = await crypto.subtle.sign('HMAC', key, new TextEncoder().encode(msg));
  return Array.from(new Uint8Array(sig)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

async function boot() {
  // 1. Check saved session
  if (sessionStorage.getItem('cp_unlocked') === 'true') { unlockApp(); return; }
  // 2. Check URL token
  const token = new URLSearchParams(location.search).get('token');
  if (token) {
    const today = new Date().toISOString().slice(0,10);
    const yesterday = new Date(Date.now()-86400000).toISOString().slice(0,10);
    const [t1, t2] = await Promise.all([hmac(today, TOKEN_SECRET), hmac(yesterday, TOKEN_SECRET)]);
    if (token === t1 || token === t2) {
      sessionStorage.setItem('cp_unlocked','true');
      history.replaceState({}, '', location.pathname);
      unlockApp(); return;
    }
  }
  // Show lock screen (already visible by default)
}

async function checkPassword() {
  const input = document.getElementById('pwInput').value;
  const [inputHash, correctHash] = await Promise.all([sha256(input), sha256(APP_PASSWORD)]);
  if (inputHash === correctHash) {
    sessionStorage.setItem('cp_unlocked','true');
    unlockApp();
  } else {
    const inp = document.getElementById('pwInput');
    document.getElementById('lockError').classList.add('visible');
    inp.classList.add('shake');
    setTimeout(()=>inp.classList.remove('shake'), 400);
    inp.value = '';
  }
}

document.getElementById('pwInput').addEventListener('keydown', e => { if(e.key==='Enter') checkPassword(); });

function unlockApp() {
  document.getElementById('lockScreen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  initApp();
}

boot();

// ── APP ──
let currentPost = '', currentTopics = [], currentTone = 'intel';

function initApp() {
  const now = new Date();
  document.getElementById('datePill').textContent = now.toLocaleDateString('en-US',{month:'short',day:'numeric'}).toUpperCase();
  document.querySelectorAll('.topic-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      const active = document.querySelectorAll('.topic-pill.active');
      if (pill.classList.contains('active')) { if(active.length>1) pill.classList.remove('active'); }
      else { if(active.length<3) pill.classList.add('active'); }
    });
  });
  document.querySelectorAll('.tone-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tone-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active'); currentTone = btn.dataset.tone;
    });
  });
}

function switchTab(name, btn) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  btn.classList.add('active');
  if(name==='history') renderHistory();
}

const tones = {
  intel: 'structured intel briefing with [ HEADER ] labels per topic. Tone: cold, authoritative, elite insider. No emojis.',
  alpha: 'alpha leak style. Start with ⚡ or 🔓. Tone: secretive, urgent, exclusive.',
  urgent: 'breaking news. Start with 🚨 or ⚠️. Tone: fast, punchy, alarming.',
  luxury: 'luxury crypto lifestyle tied to wealth, freedom, private jets. Tone: refined, aspirational.'
};

async function generatePost() {
  const topics = [...document.querySelectorAll('.topic-pill.active')].map(p=>p.dataset.topic);
  const tone = document.querySelector('.tone-btn.active').dataset.tone;
  const today = new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
  currentTopics = topics; currentTone = tone;
  const btn = document.getElementById('genBtn');
  btn.disabled=true; btn.classList.add('loading');
  document.getElementById('btnText').textContent='GENERATING...';
  document.getElementById('errorToast').classList.remove('visible');

  const prompt = `You are a crypto intel content creator for @IsabelleGassen on X.\nDate: ${today}\nTopics: ${topics.join(', ')}\nStyle: ${tones[tone]}\nWrite ONE X post:\n- [ TOPIC HEADER ] brackets per topic (ALL CAPS)\n- 1-2 punchy sentences per point\n- 2-3 #hashtags inline\n- End with 2-3 standalone hashtag lines\n- 220-260 chars, NEVER exceed 280\n- Output ONLY the post text.`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ model:'claude-sonnet-4-20250514', max_tokens:1000, messages:[{role:'user',content:prompt}] })
    });
    const data = await res.json();
    if(data.error) throw new Error(data.error.message);
    const text = data.content.map(b=>b.text||'').join('').trim();
    currentPost = text; renderPost(text);
    document.getElementById('outputWrap').classList.add('visible');
    document.getElementById('outputWrap').scrollIntoView({behavior:'smooth',block:'nearest'});
  } catch(err) {
    const et = document.getElementById('errorToast');
    et.textContent = '⚠ '+(err.message||'Generation failed. Try again.');
    et.classList.add('visible');
  }
  btn.disabled=false; btn.classList.remove('loading');
  document.getElementById('btnText').textContent='GENERATE POST';
}

function renderPost(text) {
  const html = text.replace(/\[([^\]]+)\]/g,'<span class="bracket">[$1]</span>').replace(/#(\w+)/g,'<span class="hashtag">#$1</span>');
  document.getElementById('postPreview').innerHTML = html;
  const len = text.length;
  const badge = document.getElementById('charBadge');
  badge.textContent = `${len} / 280`;
  badge.className = 'char-badge'+(len>280?' over':len>240?' warn':'');
}

function copyPost() { if(!currentPost) return; navigator.clipboard.writeText(currentPost).then(()=>showToast('COPIED TO CLIPBOARD')); }

function showCardPreview() {
  if(!currentPost) return;
  const brackets = [...currentPost.matchAll(/\[([^\]]+)\]/g)].map(m=>m[1]);
  ['xCardLabel1','xCardLabel2','xCardLabel3'].forEach((id,i)=>{
    const el=document.getElementById(id); el.textContent=brackets[i]||''; el.style.display=brackets[i]?'block':'none';
  });
  document.getElementById('xCardBody').innerHTML = currentPost.replace(/\[([^\]]+)\]/g,'<span class="bracket">[$1]</span>').replace(/#(\w+)/g,'<span class="hashtag">#$1</span>');
  document.getElementById('cardModal').classList.add('visible');
}
function closeModal() { document.getElementById('cardModal').classList.remove('visible'); }

function saveToHistory() {
  if(!currentPost) return;
  const history = getHistory();
  history.unshift({id:Date.now(), date:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}), topics:currentTopics, tone:currentTone, post:currentPost});
  localStorage.setItem('cp_history', JSON.stringify(history.slice(0,50)));
  showToast('SAVED TO HISTORY');
}

function getHistory() { try{return JSON.parse(localStorage.getItem('cp_history')||'[]')}catch{return[]} }

function renderHistory() {
  const history = getHistory();
  const list = document.getElementById('historyList');
  document.getElementById('histCount').textContent = history.length+' POSTS';
  if(!history.length){ list.innerHTML=`<div class="history-empty"><div class="empty-icon">📭</div>NO SAVED POSTS YET<br><br>Generate and tap SAVE</div>`; return; }
  list.innerHTML='';
  const cb=document.createElement('button'); cb.className='clear-all-btn'; cb.textContent='⚠ CLEAR ALL HISTORY';
  cb.onclick=()=>{if(confirm('Delete all?')){localStorage.removeItem('cp_history');renderHistory();}};
  list.appendChild(cb);
  history.forEach(e=>{
    const div=document.createElement('div'); div.className='history-item';
    div.innerHTML=`<div class="history-meta"><span class="history-date">${e.date}</span><span class="history-topics">${(e.topics||[]).join(' · ')}</span></div><div class="history-preview">${e.post}</div><div class="history-actions"><button class="hist-btn" onclick="loadH(${e.id})">LOAD</button><button class="hist-btn" onclick="copyH(${e.id})">COPY</button><button class="hist-btn del" onclick="delH(${e.id})">DELETE</button></div>`;
    list.appendChild(div);
  });
}

function loadH(id){ const e=getHistory().find(x=>x.id===id); if(!e)return; currentPost=e.post; renderPost(e.post); document.getElementById('outputWrap').classList.add('visible'); switchTab('generate',document.querySelectorAll('.nav-tab')[0]); showToast('POST LOADED'); }
function copyH(id){ const e=getHistory().find(x=>x.id===id); if(e) navigator.clipboard.writeText(e.post).then(()=>showToast('COPIED')); }
function delH(id){ localStorage.setItem('cp_history',JSON.stringify(getHistory().filter(x=>x.id!==id))); renderHistory(); }

function showToast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2000); }

if('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');
</script>

.hist-btn { background: var(--bg3); border: 1px solid var(--gold-border); border-radius: 7px; padding: 6px 10px; font-family: 'DM Mono', monospace; font-size: 8px; color: var(--muted2); cursor: pointer; letter-spacing: 1px; }
.hist-btn.del { color: var(--red); border-color: rgba(232,92,74,0.2); }
.clear-all-btn { width: 100%; background: transparent; border: 1px solid rgba(232,92,74,0.2); border-radius: 10px; padding: 12px; font-family: 'DM Mono', monospace; font-size: 10px; color: var(--red); letter-spacing: 1px; cursor: pointer; margin-bottom: 14px; }


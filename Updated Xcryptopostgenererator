.xcard-img { width: 100%; height: 155px; background: linear-gradient(160deg, #0a0a0a 0%, #1a1208 50%, #0d0d0d 100%); position: relative; overflow: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 7px; padding: 16px; }
.xcard-img::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 50%, rgba(201,168,76,0.08) 0%, transparent 60%); }

.post-preview { padding: 16px; font-size: 13.5px; line-height: 1.8; white-space: pre-wrap; word-break: break-word; min-height: 100px; }
.post-preview .bracket { color: #fff; font-weight: 600; }
.post-preview .hashtag { color: #4a9eff; }
.output-actions { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1px; background: var(--gold-border); border-top: 1px solid var(--gold-border); }
.out-btn { background: var(--bg2); border: none; padding: 12px 6px; font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 1px; color: var(--muted2); cursor: pointer; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4px; transition: all 0.15s; }

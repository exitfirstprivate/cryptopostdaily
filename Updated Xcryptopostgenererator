.xcard-footer { padding: 10px 16px 14px; display: flex; gap: 20px; color: #555; font-size: 12px; border-top: 1px solid #111; margin-top: 10px; }
.preview-actions { margin-top: 16px; display: flex; gap: 10px; width: 100%; max-width: 360px; }
.prev-btn { flex: 1; background: var(--bg3); border: 1px solid var(--gold-border); border-radius: 10px; padding: 12px; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 1px; color: var(--gold); cursor: pointer; text-align: center; }

/* HISTORY */
.history-empty { text-align: center; padding: 60px 20px; font-family: 'DM Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 1px; }
.history-empty .empty-icon { font-size: 40px; margin-bottom: 12px; opacity: 0.4; }
.history-item { background: var(--bg2); border: 1px solid var(--gold-border); border-radius: 12px; padding: 14px; margin-bottom: 10px; }
.history-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.history-date { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--gold); letter-spacing: 1px; }
.history-topics { font-family: 'DM Mono', monospace; font-size: 8px; color: var(--muted); }

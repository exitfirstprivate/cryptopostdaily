<style>
:root {
  --gold: #C9A84C; --gold-light: #e8c96a; --gold-dim: rgba(201,168,76,0.12);
  --gold-border: rgba(201,168,76,0.25); --bg: #0A0A0A; --bg2: #111; --bg3: #181818;
  --bg4: #1e1e1e; --text: #e8e0d0; --muted: #555; --muted2: #888; --red: #e85c4a;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; overflow-x: hidden; }

/* LOCK SCREEN */
#lockScreen {
  position: fixed; inset: 0; background: var(--bg);
  background-image: radial-gradient(ellipse at 60% 0%, rgba(201,168,76,0.07) 0%, transparent 60%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 32px 24px; z-index: 999;
}
.lock-logo { font-family: 'Bebas Neue', sans-serif; font-size: 42px; letter-spacing: 4px; color: var(--gold); line-height: 1; margin-bottom: 4px; }
.lock-sub { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 3px; color: var(--muted); margin-bottom: 44px; }
.lock-icon { font-size: 36px; margin-bottom: 20px; opacity: 0.6; }
.lock-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 3px; color: var(--muted); margin-bottom: 10px; }
.lock-input {
  width: 100%; max-width: 320px; background: var(--bg2); border: 1px solid var(--gold-border);
  border-radius: 12px; padding: 16px 18px; font-family: 'DM Mono', monospace; font-size: 16px;
  color: var(--text); letter-spacing: 3px; text-align: center; outline: none; margin-bottom: 12px; transition: border-color 0.2s;
}
.lock-input:focus { border-color: var(--gold); }
.lock-input.shake { animation: shake 0.3s ease; border-color: var(--red); }
@keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-8px)} 75%{transform:translateX(8px)} }
.lock-error { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--red); margin-bottom: 10px; letter-spacing: 1px; display: none; }
.lock-error.visible { display: block; }
.lock-btn {
  width: 100%; max-width: 320px; background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: #000; border: none; border-radius: 12px; padding: 16px; font-family: 'Bebas Neue', sans-serif;
  font-size: 20px; letter-spacing: 3px; cursor: pointer;
}
.lock-hint { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--muted); letter-spacing: 1px; margin-top: 20px; text-align: center; line-height: 2; }

/* APP */
#app { display: none; }
#app.unlocked { display: block; }

/* NAV */
.nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--bg2); border-top: 1px solid var(--gold-border); display: flex; z-index: 100; padding-bottom: env(safe-area-inset-bottom); }
.nav-tab { flex: 1; padding: 12px 4px 10px; text-align: center; cursor: pointer; border: none; background: none; color: var(--muted); font-family: 'DM Mono', monospace; font-size: 8px; letter-spacing: 1.5px; transition: color 0.2s; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.nav-tab .icon { font-size: 18px; }
.nav-tab.active { color: var(--gold); }

/* PAGES */
.page { display: none; padding: 0 0 80px; min-height: 100vh; animation: fadeIn 0.25s ease; }
.page.active { display: block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }

/* HEADER */
.page-header { background: var(--bg2); border-bottom: 1px solid var(--gold-border); padding: 16px; position: sticky; top: 0; z-index: 50; }
.page-header-inner { display: flex; align-items: center; justify-content: space-between; }
.header-brand { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px; color: var(--gold); line-height: 1; }
.header-sub { font-family: 'DM Mono', monospace; font-size: 8px; color: var(--muted); letter-spacing: 2px; margin-top: 2px; }
.date-pill { background: var(--gold-dim); border: 1px solid var(--gold-border); border-radius: 20px; padding: 5px 10px; font-family: 'DM Mono', monospace; font-size: 9px; color: var(--gold); letter-spacing: 1px; }

.scroll-content { padding: 16px; }
.card { background: var(--bg2); border: 1px solid var(--gold-border); border-radius: 14px; padding: 16px; margin-bottom: 14px; }
.card-label { font-family: 'DM Mono', monospace; font-size: 8px; letter-spacing: 3px; color: var(--gold); opacity: 0.7; margin-bottom: 12px; }

/* TOPICS */
.topics-grid { display: flex; flex-wrap: wrap; gap: 7px; }
.topic-pill { background: var(--bg3); border: 1px solid var(--gold-border); border-radius: 20px; padding: 6px 12px; font-size: 10px; color: var(--muted2); cursor: pointer; transition: all 0.15s; font-family: 'DM Mono', monospace; user-select: none; }
.topic-pill.active { background: var(--gold-dim); border-color: var(--gold); color: var(--gold-light); }

/* TONE */
.tone-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.tone-btn { background: var(--bg3); border: 1px solid var(--gold-border); border-radius: 10px; padding: 10px 8px; font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 1.5px; color: var(--muted2); cursor: pointer; text-align: center; transition: all 0.15s; }
.tone-btn.active { background: var(--gold-dim); border-color: var(--gold); color: var(--gold); }
.tone-emoji { font-size: 16px; display: block; margin-bottom: 4px; }

/* GEN BUTTON */
.gen-btn { width: 100%; background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: #000; border: none; border-radius: 14px; padding: 18px; font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 3px; cursor: pointer; transition: all 0.2s; margin-bottom: 16px; display: flex; align-items: center; justify-content: center; gap: 8px; }
.gen-btn:active { transform: scale(0.98); }
.gen-btn:disabled { opacity: 0.5; }
.gen-btn .spin { width: 18px; height: 18px; border: 2px solid rgba(0,0,0,0.2); border-top-color: #000; border-radius: 50%; animation: spin 0.7s linear infinite; display: none; }
.gen-btn.loading .spin { display: block; }
@keyframes spin { to{transform:rotate(360deg)} }

/* OUTPUT */
.output-wrap { background: var(--bg2); border: 1px solid var(--gold-border); border-radius: 14px; overflow: hidden; display: none; animation: fadeIn 0.3s ease; margin-bottom: 14px; }
.output-wrap.visible { display: block; }
.output-top { background: var(--bg3); padding: 10px 14px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--gold-border); }
.output-handle { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--gold); }
